@using SAPSec.Web.Constants
@{
    ViewData[ViewDataKeys.Title] = PageTitles.ErrorNotFound;
}

<div class="govuk-grid-row">
    <div class="govuk-grid-column-two-thirds">
        <h1 class="govuk-heading-l">@ViewData[ViewDataKeys.Title]</h1>
        <p class="govuk-body">
            If you typed the web address, check it is correct.
        </p>
        <p class="govuk-body">
            If you pasted the web address, check you copied the entire address.
        </p>
        @if (ViewData["ErrorDetail"] is string detail && !string.IsNullOrWhiteSpace(detail))
        {
            <h2 class="govuk-heading-m">Error details</h2>
            <pre class="govuk-body">@detail</pre>
        }
    </div>
</div>
