@using SAPSec.Web.Constants
@{
    ViewData[ViewDataKeys.Title] = PageTitles.ErrorNotFound;
}

<div class="govuk-grid-row">
    <div class="govuk-grid-column-two-thirds">
        <h1 class="govuk-heading-l">@ViewData[ViewDataKeys.Title]</h1>
        <p class="govuk-body">
            If you typed the web address, check it is correct.
        </p>
        <p class="govuk-body">
            If you pasted the web address, check you copied the entire address.
        </p>

        @if (Model.ShowErrorCode)
        {
            <p class="govuk-body">
                <strong>Error code:</strong> <code>@Model.ErrorCode</code>
            </p>
        }
        @if (Model.ShowErrorMessage)
        {
            <p class="govuk-body">
                <strong>Error message:</strong> <code class="govuk-body">@Model.ErrorMessage</code>
            </p>
        }
    </div>
</div>