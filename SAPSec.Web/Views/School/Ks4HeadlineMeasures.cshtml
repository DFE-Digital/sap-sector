@using System.Text.Json
@model SAPSec.Web.ViewModels.Ks4HeadlineMeasuresPageViewModel
@{
    Layout = "_Layout";
    ViewData["Title"] = "KS4 headline performance measures";
    var ks4YearLabels = SAPSec.Web.ViewModels.Ks4YearLabelConfig.YearByYear;
    var labels = new[] { Model.SchoolLabel, Model.SimilarSchoolsLabel, Model.LocalAuthorityLabel, Model.EnglandLabel };
    var colors = new[] { "#d53780", "#003078", "#003078", "#003078" };

    var attainmentRows = new[]
    {
        (Model.SchoolLabel, Model.SchoolAttainment8YearByYear, Model.SchoolAttainment8Display),
        (Model.SimilarSchoolsLabel, Model.SimilarSchoolsAttainment8YearByYear, Model.SimilarSchoolsAttainment8Display),
        (Model.LocalAuthorityLabel, Model.LocalAuthorityAttainment8YearByYear, Model.LocalAuthorityAttainment8Display),
        (Model.EnglandLabel, Model.EnglandAttainment8YearByYear, Model.EnglandAttainment8Display)
    };

    var engMathsRows = new[]
    {
        (Key: "this", Label: Model.SchoolLabel, Series: Model.SchoolEngMaths49YearByYear, Display: Model.SchoolEngMaths49Display),
        (Key: "similar", Label: Model.SimilarSchoolsLabel, Series: Model.SimilarSchoolsEngMaths49YearByYear, Display: Model.SimilarSchoolsEngMaths49Display),
        (Key: "la", Label: Model.LocalAuthorityLabel, Series: Model.LocalAuthorityEngMaths49YearByYear, Display: Model.LocalAuthorityEngMaths49Display),
        (Key: "england", Label: Model.EnglandLabel, Series: Model.EnglandEngMaths49YearByYear, Display: Model.EnglandEngMaths49Display)
    };

    var destinationsRows = new[]
    {
        (Key: "this", Label: Model.SchoolLabel, Series: Model.SchoolDestinationsYearByYear, Display: Model.SchoolDestinationsDisplay),
        (Key: "similar", Label: Model.SimilarSchoolsLabel, Series: Model.SimilarSchoolsDestinationsYearByYear, Display: Model.SimilarSchoolsDestinationsDisplay),
        (Key: "la", Label: Model.LocalAuthorityLabel, Series: Model.LocalAuthorityDestinationsYearByYear, Display: Model.LocalAuthorityDestinationsDisplay),
        (Key: "england", Label: Model.EnglandLabel, Series: Model.EnglandDestinationsYearByYear, Display: Model.EnglandDestinationsDisplay)
    };
}

<span class="govuk-caption-xl">@Model.SchoolDetails.Name</span>
<h1 class="govuk-heading-xl">@ViewData["Title"]</h1>

<p class="govuk-body">
    Compare this school's  KS4 headline performance measures with:
</p>

<ul class="govuk-list govuk-list--bullet">
    <li><b>50</b> similar secondary phase schools (including all-throughts)</li>
    <li>local averages</li>
    <li>national averages</li>
</ul>

<p class="govuk-body">
    Find out more about <a href="/school/@Model.SchoolDetails.Urn/what-is-a-similar-school" class="govuk-link">how the DfE defines what a similar school is</a>.
</p>

<section class="govuk-!-margin-bottom-7 govuk-!-margin-top-9 app-ks4-progress" aria-labelledby="progress8-heading">
    <h2 class="govuk-heading-m" id="progress8-heading">Progress 8</h2>
    <details class="govuk-details app-ks4-copy govuk-!-margin-bottom-3 app-ks4-details" data-module="govuk-details">
        <summary class="govuk-details__summary">
            <span class="govuk-details__summary-text">Information about Progress 8</span>
        </summary>
        <div class="govuk-details__text">
            <p class="govuk-body-s govuk-!-margin-bottom-2">
                Progress 8 shows how much progress a pupil made compared to other pupils with similar prior attainment.
            </p>
            <p class="govuk-body-s govuk-!-margin-bottom-2">
                The score shows progress compared to the national average:
            </p>
            <ul class="govuk-list govuk-list--bullet govuk-!-font-size-16 govuk-!-margin-bottom-3 app-ks4-copy-list">
                <li>a score of 0 means pupils in this school made similar progress to others with similar starting points</li>
                <li>a score of above 0 means pupils made more progress than average</li>
                <li>a score of below 0 means pupils made less progress than average</li>
            </ul>
            <p class="govuk-body-s govuk-!-margin-bottom-0">
                The confidence interval gives a range of scores the school could have achieved based on the cohort of pupils and natural variation in pupil performance across England.
            </p>
        </div>
    </details>

    <div class="app-ks4-message-panel">
        <p class="govuk-body govuk-!-margin-bottom-0">
            There are no Progress 8 scores for the academic years 2024 to 2025 and 2025 to 2026, as there is no KS2 assessment data available to calculate the baseline. This is due to COVID-19 disruption.
        </p>
    </div>
</section>

<section aria-labelledby="attainment8-heading" class="app-ks4-attainment">
    <h2 class="govuk-heading-m" id="attainment8-heading">Attainment 8</h2>
    <details class="govuk-details app-ks4-copy govuk-!-margin-bottom-4 app-ks4-details" data-module="govuk-details">
        <summary class="govuk-details__summary">
            <span class="govuk-details__summary-text">Information about Attainment 8</span>
        </summary>
        <div class="govuk-details__text">
            <p class="govuk-body-s govuk-!-margin-bottom-2">
                Attainment 8 is used to assess a pupil's achievement across their best performing 8 subjects.
            </p>
            <p class="govuk-body-s govuk-!-margin-bottom-2">
                The 8 subjects that are used in Attainment 8 are split into 3 groups:
            </p>
            <ul class="govuk-list govuk-list--bullet govuk-!-font-size-16 govuk-!-margin-bottom-2 app-ks4-copy-list">
                <li>
                    EBacc qualifications, which are both double weighted:
                    <ul class="govuk-list govuk-list--bullet govuk-!-font-size-16 govuk-!-margin-top-1 govuk-!-margin-bottom-0">
                        <li>English, if both language and literature are taken</li>
                        <li>Maths</li>
                    </ul>
                </li>
                <li>EBacc subjects, which include sciences, geography, history, and languages</li>
                <li>Open group subjects, which can include GCSEs or vocational qualifications (including any other approved GCSEs or vocational qualifications)</li>
            </ul>
            <p class="govuk-body-s govuk-!-margin-bottom-2">
                Each GCSE grade is given a points score, for example grade 9 = 9 points, grade 8 = 8 points, and so on. The score from the best 8 subjects (with English and maths counting twice) are added together to give an Attainment 8 score.
            </p>
            <p class="govuk-body-s govuk-!-margin-bottom-0">
                If a student scores high grades across these subjects, their Attainment 8 score will be higher. The maximum score a pupil can have is 90.
            </p>
        </div>
    </details>
    <div class="govuk-tabs govuk-!-margin-bottom-3 app-ks4-tabs" data-module="govuk-tabs">
        <ul class="govuk-tabs__list">
            <li class="govuk-tabs__list-item govuk-tabs__list-item--selected"><a class="govuk-tabs__tab" href="#three-year-average">3-year average</a></li>
            <li class="govuk-tabs__list-item"><a class="govuk-tabs__tab" href="#year-by-year">Year by year</a></li>
            <li class="govuk-tabs__list-item"><a class="govuk-tabs__tab" href="#table-view">Table</a></li>
        </ul>

        <div class="govuk-tabs__panel" id="three-year-average">
            <div class="app-ks4-chart-container">
                <canvas id="ks4-attainment8-school-chart"
                        class="js-chart"
                        data-type="bar"
                        data-axis-step="30"
                        data-axis-max="90"
                        data-bar-thickness="50"
                        data-category-percentage="0.7"
                        data-bar-percentage="1"
                        data-axis-suffix=""
                        data-chart='@Html.Raw(JsonSerializer.Serialize(new { labels, data = new decimal?[] { Model.SchoolAttainment8ThreeYearAverage, Model.SimilarSchoolsAttainment8ThreeYearAverage, Model.LocalAuthorityAttainment8ThreeYearAverage, Model.EnglandAttainment8ThreeYearAverage } }))'
                        data-colors='@Html.Raw(JsonSerializer.Serialize(colors))'>
                </canvas>
            </div>
        </div>

        <div class="govuk-tabs__panel govuk-tabs__panel--hidden" id="year-by-year">
            <div class="app-ks4-chart-container">
                <canvas id="ks4-attainment8-school-yearbyyear-chart"
                        class="js-chart"
                        data-type="line"
                        data-axis-step="30"
                        data-axis-max="90"
                        data-axis-suffix=""
                        data-show-x-grid="true"
                        data-show-legend="true"
                        data-show-datalabels="false"
                        data-chart='@Html.Raw(JsonSerializer.Serialize(new { labels = ks4YearLabels, datasets = new object[] { new { label = Model.SchoolLabel, data = new decimal?[] { Model.SchoolAttainment8YearByYear.Previous2, Model.SchoolAttainment8YearByYear.Previous, Model.SchoolAttainment8YearByYear.Current } }, new { label = Model.SimilarSchoolsLabel, data = new decimal?[] { Model.SimilarSchoolsAttainment8YearByYear.Previous2, Model.SimilarSchoolsAttainment8YearByYear.Previous, Model.SimilarSchoolsAttainment8YearByYear.Current } }, new { label = Model.LocalAuthorityLabel, data = new decimal?[] { Model.LocalAuthorityAttainment8YearByYear.Previous2, Model.LocalAuthorityAttainment8YearByYear.Previous, Model.LocalAuthorityAttainment8YearByYear.Current } }, new { label = Model.EnglandLabel, data = new decimal?[] { Model.EnglandAttainment8YearByYear.Previous2, Model.EnglandAttainment8YearByYear.Previous, Model.EnglandAttainment8YearByYear.Current } } } }))'
                        data-colors='@Html.Raw(JsonSerializer.Serialize(colors))'>
                </canvas>
            </div>
        </div>

        <div class="govuk-tabs__panel govuk-tabs__panel--hidden" id="table-view">
            <table class="govuk-table">
                <thead class="govuk-table__head">
                    <tr class="govuk-table__row"><th scope="col" class="govuk-table__header">School(s)</th><th scope="col" class="govuk-table__header govuk-table__header--numeric">@ks4YearLabels[0]</th><th scope="col" class="govuk-table__header govuk-table__header--numeric">@ks4YearLabels[1]</th><th scope="col" class="govuk-table__header govuk-table__header--numeric">@ks4YearLabels[2]</th><th scope="col" class="govuk-table__header govuk-table__header--numeric">3-year average</th></tr>
                </thead>
                <tbody class="govuk-table__body">
                    @foreach (var row in attainmentRows)
                    {
                        <tr class="govuk-table__row">
                            <th scope="row" class="govuk-table__header">@row.Item1</th>
                            <td class="govuk-table__cell govuk-table__cell--numeric">@row.Item2.Previous2</td>
                            <td class="govuk-table__cell govuk-table__cell--numeric">@row.Item2.Previous</td>
                            <td class="govuk-table__cell govuk-table__cell--numeric">@row.Item2.Current</td>
                            <td class="govuk-table__cell govuk-table__cell--numeric">@row.Item3</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</section>

<section aria-labelledby="eng-maths-heading" class="app-ks4-attainment govuk-!-margin-top-7">
    <h2 class="govuk-heading-m" id="eng-maths-heading">Grade achieved in English and maths GCSEs</h2>
    <div class="app-ks4-filter-row govuk-!-margin-bottom-6">
        <div class="govuk-form-group">
            <label class="govuk-label govuk-!-font-weight-bold" for="engMathsGrade">Grade</label>
            <select class="govuk-select" id="engMathsGrade" name="engMathsGrade" data-endpoint="@Url.Action("Ks4HeadlineMeasuresData", "School", new { urn = Model.SchoolDetails.Urn })">
                <option value="4" selected>Grade 4 and above</option>
                <option value="5">Grade 5 and above</option>
            </select>
        </div>
    </div>
    <div class="app-ks4-tabs govuk-tabs govuk-!-margin-top-6 govuk-!-margin-bottom-3" data-module="govuk-tabs">
        <ul class="govuk-tabs__list">
            <li class="govuk-tabs__list-item govuk-tabs__list-item--selected"><a class="govuk-tabs__tab" href="#eng-maths-three-year-average">3-year average</a></li>
            <li class="govuk-tabs__list-item"><a class="govuk-tabs__tab" href="#eng-maths-year-by-year">Year by year</a></li>
            <li class="govuk-tabs__list-item"><a class="govuk-tabs__tab" href="#eng-maths-table-view">Table</a></li>
        </ul>
        <div class="govuk-tabs__panel" id="eng-maths-three-year-average">
            <div class="app-ks4-chart-container">
                <canvas id="eng-maths-school-chart" class="js-chart" data-type="bar" data-axis-step="25" data-axis-max="100" data-axis-suffix="%" data-bar-thickness="50" data-category-percentage="0.7" data-bar-percentage="1" data-chart='@Html.Raw(JsonSerializer.Serialize(new { labels, data = new decimal?[] { Model.SchoolEngMaths49ThreeYearAverage, Model.SimilarSchoolsEngMaths49ThreeYearAverage, Model.LocalAuthorityEngMaths49ThreeYearAverage, Model.EnglandEngMaths49ThreeYearAverage } }))' data-colors='@Html.Raw(JsonSerializer.Serialize(colors))'></canvas>
            </div>
        </div>
        <div class="govuk-tabs__panel govuk-tabs__panel--hidden" id="eng-maths-year-by-year">
            <div class="app-ks4-chart-container">
                <canvas id="eng-maths-school-yearbyyear-chart" class="js-chart" data-type="line" data-axis-step="25" data-axis-max="100" data-axis-suffix="%" data-show-legend="true" data-show-datalabels="false" data-show-x-grid="true" data-chart='@Html.Raw(JsonSerializer.Serialize(new { labels = ks4YearLabels, datasets = new object[] { new { label = Model.SchoolLabel, data = new decimal?[] { Model.SchoolEngMaths49YearByYear.Previous2, Model.SchoolEngMaths49YearByYear.Previous, Model.SchoolEngMaths49YearByYear.Current } }, new { label = Model.SimilarSchoolsLabel, data = new decimal?[] { Model.SimilarSchoolsEngMaths49YearByYear.Previous2, Model.SimilarSchoolsEngMaths49YearByYear.Previous, Model.SimilarSchoolsEngMaths49YearByYear.Current } }, new { label = Model.LocalAuthorityLabel, data = new decimal?[] { Model.LocalAuthorityEngMaths49YearByYear.Previous2, Model.LocalAuthorityEngMaths49YearByYear.Previous, Model.LocalAuthorityEngMaths49YearByYear.Current } }, new { label = Model.EnglandLabel, data = new decimal?[] { Model.EnglandEngMaths49YearByYear.Previous2, Model.EnglandEngMaths49YearByYear.Previous, Model.EnglandEngMaths49YearByYear.Current } } } }))' data-colors='@Html.Raw(JsonSerializer.Serialize(colors))'></canvas>
            </div>
        </div>
        <div class="govuk-tabs__panel govuk-tabs__panel--hidden" id="eng-maths-table-view">
            <table class="govuk-table">
                <thead class="govuk-table__head"><tr class="govuk-table__row"><th scope="col" class="govuk-table__header">School(s)</th><th scope="col" class="govuk-table__header govuk-table__header--numeric">@ks4YearLabels[0]</th><th scope="col" class="govuk-table__header govuk-table__header--numeric">@ks4YearLabels[1]</th><th scope="col" class="govuk-table__header govuk-table__header--numeric">@ks4YearLabels[2]</th><th scope="col" class="govuk-table__header govuk-table__header--numeric">3-year average</th></tr></thead>
                <tbody class="govuk-table__body">
                    @foreach (var row in engMathsRows)
                    {
                        <tr class="govuk-table__row">
                            <th scope="row" class="govuk-table__header">@row.Label</th>
                            <td class="govuk-table__cell govuk-table__cell--numeric" data-eng-maths-cell="@($"{row.Key}-prev2")">@SAPSec.Web.ViewModels.Ks4HeadlineMeasuresPageViewModel.DisplayPercent(row.Series.Previous2)</td>
                            <td class="govuk-table__cell govuk-table__cell--numeric" data-eng-maths-cell="@($"{row.Key}-prev")">@SAPSec.Web.ViewModels.Ks4HeadlineMeasuresPageViewModel.DisplayPercent(row.Series.Previous)</td>
                            <td class="govuk-table__cell govuk-table__cell--numeric" data-eng-maths-cell="@($"{row.Key}-current")">@SAPSec.Web.ViewModels.Ks4HeadlineMeasuresPageViewModel.DisplayPercent(row.Series.Current)</td>
                            <td class="govuk-table__cell govuk-table__cell--numeric" data-eng-maths-cell="@($"{row.Key}-avg")">@row.Display</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</section>

<section aria-labelledby="destinations-heading" class="app-ks4-attainment govuk-!-margin-top-7">
    <h2 class="govuk-heading-m" id="destinations-heading">Staying in education or entering employment</h2>
    <details class="govuk-details app-ks4-copy govuk-!-margin-bottom-3 app-ks4-details" data-module="govuk-details">
        <summary class="govuk-details__summary">
            <span class="govuk-details__summary-text">Information about staying in education or entering employment data</span>
        </summary>
        <div class="govuk-details__text">
            <p class="govuk-body-s govuk-!-margin-bottom-2">
                This data shows the number of pupils who either stayed in education, started an apprenticeship, or entered employment for at least two terms after completing key stage 4.
            </p>
            <p class="govuk-body-s govuk-!-margin-bottom-2">
                The most recent data covers pupils who finished year 11 in 2023. The three-year average is the average of pupils completed year 11 in 2021,2022 and 2023.
            </p>
        </div>
    </details>
    <div class="app-ks4-filter-row govuk-!-margin-bottom-6">
        <div class="govuk-form-group">
            <label class="govuk-label govuk-!-font-weight-bold" for="destinationsType">Destination</label>
            <select class="govuk-select" id="destinationsType" name="destinationsType" data-endpoint="@Url.Action("Ks4DestinationsData", "School", new { urn = Model.SchoolDetails.Urn })">
                <option value="all" selected>All destinations</option>
                <option value="education">Education</option>
                <option value="employment">Employment and apprenticeships</option>
            </select>
        </div>
    </div>
    <div class="app-ks4-tabs govuk-tabs govuk-!-margin-top-6" data-module="govuk-tabs">
        <ul class="govuk-tabs__list">
            <li class="govuk-tabs__list-item govuk-tabs__list-item--selected"><a class="govuk-tabs__tab" href="#destinations-three-year-average">3-year average</a></li>
            <li class="govuk-tabs__list-item"><a class="govuk-tabs__tab" href="#destinations-year-by-year">Year by year</a></li>
            <li class="govuk-tabs__list-item"><a class="govuk-tabs__tab" href="#destinations-table-view">Table</a></li>
        </ul>
        <div class="govuk-tabs__panel" id="destinations-three-year-average">
            <div class="app-ks4-chart-container">
                <canvas id="destinations-school-chart" class="js-chart" data-type="bar" data-axis-step="25" data-axis-max="100" data-axis-suffix="%" data-value-decimals="0" data-bar-thickness="50" data-category-percentage="0.7" data-bar-percentage="1" data-chart='@Html.Raw(JsonSerializer.Serialize(new { labels, data = new decimal?[] { Model.SchoolDestinationsThreeYearAverage, Model.SimilarSchoolsDestinationsThreeYearAverage, Model.LocalAuthorityDestinationsThreeYearAverage, Model.EnglandDestinationsThreeYearAverage } }))' data-colors='@Html.Raw(JsonSerializer.Serialize(colors))'></canvas>
            </div>
        </div>
        <div class="govuk-tabs__panel govuk-tabs__panel--hidden" id="destinations-year-by-year">
            <div class="app-ks4-chart-container">
                <canvas id="destinations-school-yearbyyear-chart" class="js-chart" data-type="line" data-axis-step="25" data-axis-max="100" data-axis-suffix="%" data-show-legend="true" data-show-datalabels="false" data-show-x-grid="true" data-chart='@Html.Raw(JsonSerializer.Serialize(new { labels = ks4YearLabels, datasets = new object[] { new { label = Model.SchoolLabel, data = new decimal?[] { Model.SchoolDestinationsYearByYear.Previous2, Model.SchoolDestinationsYearByYear.Previous, Model.SchoolDestinationsYearByYear.Current } }, new { label = Model.SimilarSchoolsLabel, data = new decimal?[] { Model.SimilarSchoolsDestinationsYearByYear.Previous2, Model.SimilarSchoolsDestinationsYearByYear.Previous, Model.SimilarSchoolsDestinationsYearByYear.Current } }, new { label = Model.LocalAuthorityLabel, data = new decimal?[] { Model.LocalAuthorityDestinationsYearByYear.Previous2, Model.LocalAuthorityDestinationsYearByYear.Previous, Model.LocalAuthorityDestinationsYearByYear.Current } }, new { label = Model.EnglandLabel, data = new decimal?[] { Model.EnglandDestinationsYearByYear.Previous2, Model.EnglandDestinationsYearByYear.Previous, Model.EnglandDestinationsYearByYear.Current } } } }))' data-colors='@Html.Raw(JsonSerializer.Serialize(colors))'></canvas>
            </div>
        </div>
        <div class="govuk-tabs__panel govuk-tabs__panel--hidden" id="destinations-table-view">
            <table class="govuk-table">
                <thead class="govuk-table__head"><tr class="govuk-table__row"><th scope="col" class="govuk-table__header">School(s)</th><th scope="col" class="govuk-table__header govuk-table__header--numeric">@ks4YearLabels[0]</th><th scope="col" class="govuk-table__header govuk-table__header--numeric">@ks4YearLabels[1]</th><th scope="col" class="govuk-table__header govuk-table__header--numeric">@ks4YearLabels[2]</th><th scope="col" class="govuk-table__header govuk-table__header--numeric">3-year average</th></tr></thead>
                <tbody class="govuk-table__body">
                    @foreach (var row in destinationsRows)
                    {
                        <tr class="govuk-table__row">
                            <th scope="row" class="govuk-table__header">@row.Label</th>
                            <td class="govuk-table__cell govuk-table__cell--numeric" data-destinations-cell="@($"{row.Key}-prev2")">@SAPSec.Web.ViewModels.Ks4HeadlineMeasuresPageViewModel.DisplayWholePercent(row.Series.Previous2)</td>
                            <td class="govuk-table__cell govuk-table__cell--numeric" data-destinations-cell="@($"{row.Key}-prev")">@SAPSec.Web.ViewModels.Ks4HeadlineMeasuresPageViewModel.DisplayWholePercent(row.Series.Previous)</td>
                            <td class="govuk-table__cell govuk-table__cell--numeric" data-destinations-cell="@($"{row.Key}-current")">@SAPSec.Web.ViewModels.Ks4HeadlineMeasuresPageViewModel.DisplayWholePercent(row.Series.Current)</td>
                            <td class="govuk-table__cell govuk-table__cell--numeric" data-destinations-cell="@($"{row.Key}-avg")">@row.Display</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</section>

@section Scripts {
    <script src="~/js/chart.umd.js" asp-append-version="true" add-nonce="true"></script>
    <script src="~/js/chartjs-plugin-datalabels.min.js" asp-append-version="true" add-nonce="true"></script>
    <script src="~/js/chart-factory.js" asp-append-version="true" add-nonce="true"></script>
    <script src="~/js/school-ks4-grade-switcher.js" asp-append-version="true" add-nonce="true"></script>
    <script src="~/js/school-ks4-destinations-switcher.js" asp-append-version="true" add-nonce="true"></script>
    <script src="~/js/similar-schools-tabs-mobile-fix.js" asp-append-version="true" add-nonce="true"></script>
}
