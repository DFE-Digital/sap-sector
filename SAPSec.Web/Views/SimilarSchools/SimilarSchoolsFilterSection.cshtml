@using SAPSec.Core.Features.Filtering
@using SAPSec.Core.Features.SimilarSchools.UseCases
@using SAPSec.Web.Helpers;

@model SimilarSchoolsAvailableFilter

@{
    var sectionId = $"filter-{Model.Key}";
    (var hasSelection, var hasErrors) = Model switch
    {
        SimilarSchoolsSingleValueAvailableFilter s =>
            (s.Options.Any(o => o.Selected), false),
        SimilarSchoolsMultiValueAvailableFilter m =>
            (m.Options.Any(o => o.Selected), false),
        SimilarSchoolsNumericRangeAvailableFilter r =>
            (!string.IsNullOrWhiteSpace(r.From.Value) || !string.IsNullOrWhiteSpace(r.To.Value), r.ValidationErrors.Any()),
        _ => (false, false)
    };
    var isExpanded = hasSelection || hasErrors ? "true" : "false";
    var isLastInGroup = ViewData["IsLastInGroup"] as bool? ?? false;
    var sectionClasses = isLastInGroup ? "app-filter-section" : "app-filter-section app-filter-section--divider";
}

<div class="@sectionClasses" data-module="app-filter-section">
    <div class="govuk-form-group @(hasErrors? "govuk-form-group--error" : "")">
        <button type="button"
                class="app-filter-section__toggle"
                aria-expanded="@isExpanded"
                aria-controls="@sectionId">
            <span class="app-filter-section__title">@Model.Name</span>
            <span class="app-filter-section__indicator">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <path fill-rule="evenodd" clip-rule="evenodd"
                          d="M11.9999 10.5177L17.7928 16.3105L19.207 14.8963L11.9999 7.68923L4.79282 14.8963L6.20703 16.3105L11.9999 10.5177Z"
                          fill="currentColor"></path>
                </svg>
            </span>
        </button>

        <div class="app-filter-section__content" id="@sectionId" @(hasSelection ? "" : "hidden")>
            @if (Model.Key.Equals("dist", StringComparison.InvariantCultureIgnoreCase))
            {
                <p class="govuk-hint">Miles from selected school</p>
            }
            else if (Model.Key.Equals("sciu", StringComparison.InvariantCultureIgnoreCase))
            {
                <p class="govuk-hint">Percentage of school&acute;s total pupil capacity being used</p>
            }
            else if (Model.Key.Equals("oar", StringComparison.InvariantCultureIgnoreCase))
            {
                <p class="govuk-hint">Percentage of sessions recorded as absent from school for any reason</p>
            }
            else if (Model.Key.Equals("par", StringComparison.InvariantCultureIgnoreCase))
            {
                <p class="govuk-hint">Percentage of pupils who miss 10% of sessions or more for any reason</p>
            }

            @if (Model is SimilarSchoolsSingleValueAvailableFilter single)
            {
                <div class="govuk-radios govuk-radios--small">
                    @foreach (var option in single.Options)
                    {
                        var inputId = $"{Model.Key}-{option.Key.Replace(" ", "-").Replace("%", "pct").Replace("(", "").Replace(")", "").ToLower()}";
                        <div class="govuk-radios__item">
                            <input class="govuk-radios__input"
                                   id="@inputId"
                                   name="@Model.Key"
                                   type="radio"
                                   value="@option.Key"
                                   @(option.Selected ? "checked" : "")>
                            <label class="govuk-label govuk-radios__label" for="@inputId">
                                @option.Name
                            </label>
                        </div>
                    }
                </div>
            }
            else if (Model is SimilarSchoolsMultiValueAvailableFilter multi)
            {
                <div class="govuk-checkboxes govuk-checkboxes--small">
                    @foreach (var option in multi.Options)
                    {
                        var inputId = $"{Model.Key}-{option.Key.Replace(" ", "-").Replace("(", "").Replace(")", "").ToLower()}";
                        <div class="govuk-checkboxes__item">
                            <input class="govuk-checkboxes__input"
                                   id="@inputId"
                                   name="@Model.Key"
                                   type="checkbox"
                                   value="@option.Key"
                                   @(option.Selected ? "checked" : "")>
                            <label class="govuk-label govuk-checkboxes__label" for="@inputId">
                                @option.Name
                            </label>
                        </div>
                    }
                </div>
            }
            else if (Model is SimilarSchoolsNumericRangeAvailableFilter range)
            {
                @foreach (var error in range.ValidationErrors)
                {
                    <p id="@(error.Key)-error" class="govuk-error-message">
                        <span class="govuk-visually-hidden">Error:</span> @error.Message
                    </p>
                }

                var fromError = range.ValidationErrors.Any(v => v.Key == range.From.Key || v.Key == Model.Key);
                var toError = range.ValidationErrors.Any(v => v.Key == range.To.Key || v.Key == Model.Key);

                <div class="app-filter-range">
                    <div class="app-filter-range__from">
                        <label class="govuk-label" for=@range.From.Key>From</label>
                        <div class="app-filter-range__input">
                            <input class="govuk-input @(fromError? "govuk-input--error" : "")"
                                   id=@range.From.Key
                                   name=@range.From.Key
                                   type="text"
                                   value="@range.From.Value" />
                        </div>
                    </div>
                    <div class="app-filter-range__to">
                        <label class="govuk-label" for=@range.To.Key>To</label>
                        <div class="app-filter-range__input">
                            <input class="govuk-input @(toError? "govuk-input--error" : "")"
                                   id=@range.To.Key
                                   name=@range.To.Key
                                   type="text"
                                   value="@range.To.Value" />
                        </div>
                    </div>
                </div>
            }

            @if (Model.CurrentSchoolValue is not null)
            {
                <div class="govuk-inset-text app-filter-inset-light-blue govuk-!-margin-top-2 govuk-!-margin-bottom-0">
                    <strong>This School:</strong> @Model.CurrentSchoolValue.Display()
                </div>
            }
        </div>
    </div>

</div>
