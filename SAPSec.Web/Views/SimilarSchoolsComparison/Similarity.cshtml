@using SAPSec.Web.ViewModels
@model SAPSec.Web.ViewModels.SimilarSchoolsComparisonViewModel
@{
    Layout = "_Layout";
}

<h1 class="govuk-heading-l">How these schools compare</h1>

<p class="govuk-body">
    This school is part of a group of <strong>50</strong> schools that the DfE has identified as similar
    based on 9 key characteristics.
</p>

<p class="govuk-body">
    Learn <a href="@Url.Action("WhatIsASimilarSchool", "School", new { urn = Model.Urn })" class="govuk-link">
        more about this data and how DfE identifies what a similar school is.
    </a>
</p>

<div class="govuk-!-margin-top-8">
    <table class="govuk-table govuk-table--responsive">
        <thead class="govuk-table__head">
        <tr class="govuk-table__row">
            <th scope="col" class="govuk-table__header govuk-!-width-one-half">Characteristic</th>
            <th scope="col" class="govuk-table__header govuk-!-width-one-quarter">@Model.Name</th>
            <th scope="col" class="govuk-table__header govuk-!-width-one-quarter">@Model.SimilarSchoolName</th>
            <th scope="col" class="govuk-table__header govuk-!-width-one-quarter">Similarity</th>
        </tr>
        </thead>

        <tbody class="govuk-table__body">
        @foreach (var row in Model.CharacteristicsRows)
        {
            <tr class="govuk-table__row">
                <th scope="row" class="govuk-table__header">@row.Characteristic</th>
                
                <td class="govuk-table__cell">@row.CurrentSchoolValue</td>
                <td class="govuk-table__cell">@row.SimilarSchoolValue</td>

                <td class="govuk-table__cell">
                    @switch (row.Similarity)
                    {
                        case SimilarSchoolsComparisonViewModel.SimilarityLabel.Similar:
                            <strong class="govuk-tag govuk-tag--green" style="white-space: nowrap;">Similar</strong>
                            break;
                        case SimilarSchoolsComparisonViewModel.SimilarityLabel.LessSimilar:
                            <strong class="govuk-tag govuk-tag--yellow" style="white-space: nowrap;">Less similar</strong>
                            break;
                        default:
                            <strong class="govuk-tag govuk-tag--red" style="white-space: nowrap;">Not similar</strong>
                            break;
                    }
                </td>
            </tr>
        }
        </tbody>
    </table>
</div>
