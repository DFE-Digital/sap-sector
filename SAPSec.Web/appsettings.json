{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.AspNetCore.Authentication": "Warning",
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.Hosting.Lifetime": "Warning",
        "System": "Warning",
        "SAPSec.Web": "Debug"
      }
    },
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "formatter": "Serilog.Formatting.Compact.RenderedCompactJsonFormatter, Serilog.Formatting.Compact"
        }
      }
    ],
    "Enrich": [ "FromLogContext", "WithMachineName", "WithThreadId" ]
  },
  "AllowedHosts": "*",
  "Analytics": {
    "GoogleTagManagerIds": {
      "test": "GTM-M3BPJWJD",
      "production": "GTM-M3BPJWJD"
    },
    "GoogleTagManagerAdditionals": {
      "test": "&gtm_auth=nKIhOyT9eOYmtTUZQI46ag&gtm_preview=env-14&gtm_cookies_win=x",
      "production": "&gtm_auth=tHioL-Kyfdf0DzFP8eko-g&gtm_preview=env-13&gtm_cookies_win=x"
    },
    "ClarityIds": {
      "test": "vmzvlwvw68",
      "production": "vmzv8ur28m"
    }
  },
  "DsiConfiguration": {
    "ServiceName": "SAP Sector Service",
    "CallbackPath": "/signin-oidc",
    "SignedOutCallbackPath": "/signout-callback-oidc",
    "RequireHttpsMetadata": true,
    "ValidateIssuer": true,
    "ValidateAudience": true,
    "ValidateLifetime": true,
    "TokenExpiryMinutes": 60
  }
}
