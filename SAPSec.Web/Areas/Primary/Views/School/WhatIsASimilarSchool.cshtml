@using SAPSec.Core.Model
@using SAPSec.Web.Helpers
@model SchoolDetails
@{
    Layout = "_Layout";
    ViewData["Title"] = "What is a similar school?";
}

<div class="app-primary-similar-school">
    <header class="app-primary-similar-school__header">
        <p class="govuk-body-l app-primary-similar-school__caption">@Model.Name</p>
        <h1 class="govuk-heading-xl app-primary-similar-school__title">What is a similar school?</h1>
    </header>

    <section class="app-primary-similar-school__section">
        <p class="govuk-body app-primary-similar-school__lead">
            The DfE has identified a group of <strong>50</strong> similar primary phase schools (including all-throughs) by comparing schools against criteria based on characteristics such as levels of disadvantage, SEN support, prior attainment, and pupil numbers.
        </p>
    </section>

    <section class="app-primary-similar-school__section">
        <h2 class="govuk-heading-m app-primary-similar-school__section-heading">Criteria used to find similar schools</h2>

        <table class="govuk-table app-primary-similar-school__table">
            <thead class="govuk-table__head">
                <tr class="govuk-table__row">
                    <th scope="col" class="govuk-table__header">Criteria</th>
                    <th scope="col" class="govuk-table__header">Description</th>
                </tr>
            </thead>
            <tbody class="govuk-table__body">
                <tr class="govuk-table__row">
                    <td class="govuk-table__cell govuk-!-font-weight-bold app-primary-similar-school__criteria">Total number of pupils</td>
                    <td class="govuk-table__cell">Ages 4-11</td>
                </tr>
                <tr class="govuk-table__row">
                    <td class="govuk-table__cell govuk-!-font-weight-bold app-primary-similar-school__criteria">Pupil stability rate</td>
                    <td class="govuk-table__cell">Percentage of pupils admitted to the school at the standard time of admission</td>
                </tr>
                <tr class="govuk-table__row">
                    <td class="govuk-table__cell govuk-!-font-weight-bold app-primary-similar-school__criteria">Eligibility for pupil premium</td>
                    <td class="govuk-table__cell">Proportion of pupils eligible for pupil premium</td>
                </tr>
                <tr class="govuk-table__row">
                    <td class="govuk-table__cell govuk-!-font-weight-bold app-primary-similar-school__criteria">Average IDACI score</td>
                    <td class="govuk-table__cell">
                        Proportion of children aged 0 to 15 in an area who live in income deprived families.
                        <p class="govuk-body app-primary-similar-school__table-link">
                            <a href="https://www.gov.uk/government/statistics/english-indices-of-deprivation-2025/english-indices-of-deprivation-2025-statistical-release" class="govuk-link">Find out more about English indices of deprivation.</a>
                        </p>
                    </td>
                </tr>
                <tr class="govuk-table__row">
                    <td class="govuk-table__cell govuk-!-font-weight-bold app-primary-similar-school__criteria">Average POLAR4 quintile</td>
                    <td class="govuk-table__cell">
                        Areas across the UK classified into quintiles based on the proportion of young people who enter higher education.
                        <p class="govuk-body app-primary-similar-school__table-link">
                            <a href="https://www.officeforstudents.org.uk/data-and-analysis/young-participation-by-area/about-polar-and-adult-he/" class="govuk-link">Find out more on the Office for Students website.</a>
                        </p>
                    </td>
                </tr>
                <tr class="govuk-table__row">
                    <td class="govuk-table__cell govuk-!-font-weight-bold app-primary-similar-school__criteria">Percentage of pupils with an EHC plan</td>
                    <td class="govuk-table__cell">Education, health and care plan</td>
                </tr>
                <tr class="govuk-table__row">
                    <td class="govuk-table__cell govuk-!-font-weight-bold app-primary-similar-school__criteria">Percentage of pupils with SEN support</td>
                    <td class="govuk-table__cell">SEN pupils without EHC plans</td>
                </tr>
                <tr class="govuk-table__row">
                    <td class="govuk-table__cell govuk-!-font-weight-bold app-primary-similar-school__criteria">Percentage of pupils with EAL</td>
                    <td class="govuk-table__cell">English as an additional language</td>
                </tr>
            </tbody>
        </table>
    </section>

    <section class="app-primary-similar-school__section">
        <h2 class="govuk-heading-m app-primary-similar-school__section-heading">Which schools have been identified as similar?</h2>
        <p class="govuk-body">
            While schools may not match on every criteria, the schools have matched because they share a large number of them.
        </p>
        <p class="govuk-body">
            You can <a href="/school/primary/@Model.Urn/view-similar-schools" class="govuk-link">view all the schools most similar to this one</a> and select individual schools to see its similarity, performance and contact details.
        </p>
    </section>

    <section class="app-primary-similar-school__section">
        <h2 class="govuk-heading-m app-primary-similar-school__section-heading">Annual updates to similar schools data</h2>
        <p class="govuk-body">
            As school characteristics such as levels of disadvantage and SEN support change over time, the group of similar schools you are matched with will be updated annually.
        </p>
        <p class="govuk-body">
            When this update occurs, the 3-year average and year-on-year average for similar schools will also change to show data only from the newest set of similar schools.
        </p>
    </section>
</div>
